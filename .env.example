# Copy to .env.local and fill in what you have. Everything is optional and the
# app runs with none of it — but adding keys is what makes an investigation
# WIDE. Without a search key, web search falls back to keyless Bing/DuckDuckGo
# scraping, which is frequently rate-limited and returns nothing.
#
# Recommended for the full experience: SERPER_API_KEY + GITHUB_TOKEN (both free).
# The rest are optional.

# Real Google results + site:instagram.com / site:linkedin.com social search.
# Free tier at https://serper.dev — the most impactful key for breadth.
SERPER_API_KEY=

# Alternative search provider. Free tier at https://brave.com/search/api
BRAVE_API_KEY=

# Raises the GitHub API limit from 60 to 5,000/hr and powers commit-email mining.
# Create a no-scopes (public-only) token at https://github.com/settings/tokens
GITHUB_TOKEN=

# Professional emails on a domain. Free tier at https://hunter.io
HUNTER_API_KEY=

# Claude writes the report narrative from collected facts (never invents).
# Without it, a deterministic analyst writes the full report.
ANTHROPIC_API_KEY=

# Abuse limits for a shared public deployment. Leave unset to run unlimited
# (self-host). Set them so visitors can't drain your search-key budget.
# GRAPHLINE_DAILY_OWNER_CAP=60
# GRAPHLINE_DAILY_PER_IP=25
# GRAPHLINE_MAX_CONCURRENT=4
